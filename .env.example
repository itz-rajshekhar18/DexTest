# DexTest environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored and is the file actually used at runtime.

# --- Question generation (OpenRouter) ---
# Used server-side to generate IQ questions with the Qwen model.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model used for question generation (optional, this is the default).
QUESTION_MODEL=qwen/qwen3.5-9b

# --- Text-to-speech (ElevenLabs) ---
# Reads questions and feedback aloud.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# Optional: override the default voice.
# ELEVENLABS_VOICE_ID=your_voice_id_here

# --- Speech-to-text (DexLabs English ASR) ---
ASR_API_URL=https://dexschool.dexlabsai.in/v1/english-asr
