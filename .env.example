# OpenAI API Configuration (primary - used for questions and reports)
# Put the real key in `.env.local`, not in `.env.example`
OPENAI_API_KEY=your_openai_api_key_here
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Configuration (fallback)
NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configurations
NEXT_PUBLIC_IQ_MODEL=gpt-4o-mini
NEXT_PUBLIC_REPORT_MODEL=gpt-4o-mini
NEXT_PUBLIC_TTS_MODEL=gpt-4o-mini

# ElevenLabs Voice Configuration (optional - for voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2

# Firebase Configuration (already in lib/firebase.ts)
# Add your Firebase config in lib/firebase.ts
