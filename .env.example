# OpenRouter API Configuration
# Put the real key in `.env.local`, not in `.env.example`
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional fallback for old client-side code paths
NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configurations
# Used by the written IQ agent and oral IQ agent
NEXT_PUBLIC_TTS_MODEL=google/gemini-flash-1.5-8b
NEXT_PUBLIC_IQ_MODEL=openrouter/auto
OPENROUTER_FREE_IQ_MODEL=openai/gpt-oss-20b:free
# Optional override for the session report agent
NEXT_PUBLIC_REPORT_MODEL=openrouter/auto

# Firebase Configuration (already in lib/firebase.ts)
# Add your Firebase config in lib/firebase.ts
