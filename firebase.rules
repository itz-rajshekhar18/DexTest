rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - Allow public read and write for registration
    // This allows students to register and check if signup codes are taken
    match /users/{userId} {
      // Allow reading to check if signup code exists
      allow read: if true;
      
      // Allow creating new user documents (registration)
      allow create: if true;
      
      // Prevent updates and deletes for now (add auth later if needed)
      allow update, delete: if false;
    }
    
    // Default: Deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
